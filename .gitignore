# Dependencies
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.env.local
*.env

# API Keys — NEVER commit these
**/api_key*
**/secret*

# SSH Keys — NEVER commit
cybergym-key.pem
*.pem

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# CyberGym data (too large for git)
cybergym_data/
cybergym-server-data/
*.tar.gz
*.7z

# Docker & logs
*.log

# Experiment outputs (commit only summaries)
data/results/**/logs/
data/results/**/tmp/
data/results/**/*.log

# Large analysis files
analysis/figures/*.png
!analysis/figures/.gitkeep

# Temporary / debug scripts
*.tmp
*.bak
*.backup

# LaTeX build artifacts
IEEE Access/*.aux
IEEE Access/*.bbl
IEEE Access/*.blg
IEEE Access/*.fdb_latexmk
IEEE Access/*.fls
IEEE Access/*.out
IEEE Access/*.synctex.gz
IEEE Access/*.pdf
docs/research_paper/*.aux
docs/research_paper/*.bbl
docs/research_paper/*.blg
docs/research_paper/*.fdb_latexmk
docs/research_paper/*.fls
docs/research_paper/*.out
docs/research_paper/*.synctex.gz

# Test/debug scripts (not needed in repo)
scripts/test_*.py
scripts/check_*.py
scripts/inspect_*.py
scripts/count_*.py
scripts/*.sh